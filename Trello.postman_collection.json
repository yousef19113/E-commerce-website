    {
      "name": "Create Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "    var jsonData = pm.response.json();\r",
              "\r",
              "pm.collectionVariables.set(\"BoardId\", jsonData.id);\r",
              "\r",
              "pm.test(\"Closed as string = 'false'\", function () {\r",
              "    pm.expect(String(jsonData.closed)).to.eql(\"false\");\r",
              "});\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Check The Name\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.name).to.eql(\"New Board\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
